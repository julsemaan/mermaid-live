{
  "name": "mermaid-live",
  "version": "0.1.0",
  "private": true,
  "description": "Refactored Mermaid live renderer scaffold",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mermaid-live": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --check .",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "pino": "^9.6.0",
    "yargs": "^18.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^22.13.10",
    "@types/yargs": "^17.0.33",
    "eslint": "^9.22.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1"
  }
}
