{
  "name": "mermaid-live",
  "version": "0.1.0",
  "private": true,
  "description": "Refactored Mermaid live renderer scaffold",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mermaid-live": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --check .",
    "test": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:unit": "node --import tsx --test test/application/**/*.test.ts",
    "test:integration": "node --import tsx --test test/integration/**/*.test.ts",
    "test:e2e": "node --import tsx --test test/e2e/**/*.test.ts",
    "test:coverage": "c8 --reporter=text --reporter=lcov --check-coverage --lines 80 --functions 80 --branches 70 --statements 80 npm run test:unit",
    "bench:phase5": "node --import tsx scripts/benchmarks/phase5-benchmark.ts",
    "perf:check": "node --import tsx scripts/benchmarks/phase5-benchmark.ts --check",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "pino": "^9.6.0",
    "yargs": "^18.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^22.13.10",
    "@types/yargs": "^17.0.33",
    "c8": "^10.1.3",
    "eslint": "^9.22.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1"
  }
}
